datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  role           Role      @default(USER)
  firstName      String
  lastName       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  submittedApps  App[]     @relation("SubmittedApps")
  approvedApps   App[]     @relation("ApprovedApps")
  reviews        Review[]
  feedback       Feedback[]
  forumPosts     ForumPost[]
  forumAnswers   ForumAnswer[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  apps        App[]
  questions   CategoryQuestion[]
}

model CategoryQuestion {
  id          String    @id @default(uuid())
  categoryId  String
  question    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    Category  @relation(fields: [categoryId], references: [id])
  answers     ReviewQuestionAnswer[]
}

model App {
  id                String         @id @default(uuid())
  title             String
  description       String
  playstoreLink     String?
  appstoreLink      String?
  youtubeTutorialUrl String?
  categoryId        String
  submitterId       String
  approverId        String?
  approvalStatus    ApprovalStatus @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  category          Category       @relation(fields: [categoryId], references: [id])
  submitter         User           @relation("SubmittedApps", fields: [submitterId], references: [id])
  approver          User?          @relation("ApprovedApps", fields: [approverId], references: [id])
  reviews           Review[]
  forumPosts        ForumPost[]
}

model Review {
  id              String         @id @default(uuid())
  appId           String
  userId          String
  rating          Int            // Overall rating e.g., 1-5
  content         String
  approvalStatus  ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  app             App            @relation(fields: [appId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  questionAnswers ReviewQuestionAnswer[]
}

model ReviewQuestionAnswer {
  id              String           @id @default(uuid())
  reviewId        String
  questionId      String
  answerRating    Int              
  createdAt       DateTime         @default(now())

  review          Review           @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  question        CategoryQuestion @relation(fields: [questionId], references: [id])
}

model Feedback {
  id              String         @id @default(uuid())
  userId          String
  content         String
  approvalStatus  ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id])
}

model ForumPost {
  id              String         @id @default(uuid())
  appId           String
  userId          String
  title           String
  content         String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  app             App            @relation(fields: [appId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  answers         ForumAnswer[]
}

model ForumAnswer {
  id              String         @id @default(uuid())
  postId          String
  userId          String
  content         String
  isAccepted      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  post            ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id])
}
